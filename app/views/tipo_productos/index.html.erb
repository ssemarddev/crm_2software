<p id="notice"><%= notice %></p>

<h1>Tipo Productos
  <%= link_to 'Nuevo Tipo de Producto <i class="fa fa-plus"></i>'.html_safe , new_tipo_producto_path, class: 'btn btn-primary' %>
  <% if params[:deleted] %>
    <%= link_to 'Regresar'.html_safe , tipo_productos_path, class: 'btn btn-default' %>
  <% else %>
    <%= link_to 'Ver Papelera <i class="fa fa-trash"></i>'.html_safe , tipo_productos_path(deleted: true), class: 'btn btn-danger' %>
  <% end %>
</h1>

<table id="productos" class="table table-condensed dataTable">
  <thead>
    <tr>
      <th>Nombre</th>
      <th>Es servicio</th>
      <th>Creado</th>
      <th>Actualizado</th>
      <th></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @tipo_productos.each do |tipo_producto| %>
      <tr>
        <td class="<%= 'tr-'+tipo_producto.Estado.to_s %>"><%= tipo_producto.Nombre %></td>
        <td class="<%= 'tr-'+tipo_producto.Estado.to_s %>"><%= tipo_producto.Es_Servicio %></td>
        <td class="<%= 'tr-'+tipo_producto.Estado.to_s %>"><%= tipo_producto.creado %></td>
        <td class="<%= 'tr-'+tipo_producto.Estado.to_s %>"><%= tipo_producto.actualizado %></td>
        <!--<td><%= link_to  icon('fa','eye'), tipo_producto, class:'btn btn-info' %></td>-->
        <td class="<%= 'tr-'+tipo_producto.Estado.to_s %>"><%= link_to icon('fa','edit'), edit_tipo_producto_path(tipo_producto), class:'btn btn-warning' %></td>
        <td class="<%= 'tr-'+tipo_producto.Estado.to_s %>"><%= link_to icon('fa','trash-o'), tipo_producto, method: :delete, data: { confirm: 'Estas Seguro?' }, class:'btn btn-danger' %></td>
      </tr>
    <% end %>
  </tbody>
</table>
