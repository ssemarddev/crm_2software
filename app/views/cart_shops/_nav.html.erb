<div class="catalog-navbar">
  <div class="catalog-navbar__inner">

    <div class="catalog-navbar__brand">
      <%= link_to chooseBodega_url, class: "catalog-navbar__logo-link" do %>
        <%= image_tag "logo.png", alt: "Logo MarcoCel", class: "catalog-navbar__logo" %>
      <% end %>
    </div>

    <div class="catalog-navbar__search-area">
      <form id="catalog-search-form" action="/online_catalog" method="GET" class="catalog-search-form">
        <div class="catalog-search-form__row">
          <input
            id="catalog-search-input"
            type="text"
            name="producto"
            value="<%= params[:producto] %>"
            class="catalog-search-form__input"
            placeholder="Buscar producto...">

          <button type="submit" class="catalog-search-form__button">
            Buscar
          </button>
        </div>

        <div class="catalog-search-form__filters">
          <select class="catalog-search-form__select" name="categoria" id="catalog-category">
            <option value="">Categorias...</option>
            <% @categoriasCatalogo.each do |categoria| %>
              <option value="<%= categoria.id %>" <%= 'selected' if params[:categoria].to_s == categoria.id.to_s %>>
                <%= categoria.Nombre %>
              </option>
            <% end %>
          </select>

          <select class="catalog-search-form__select" name="marca" id="catalog-brand">
            <option value="">Marcas...</option>
            <% @marcas.each do |marca| %>
              <option value="<%= marca.id %>" <%= 'selected' if params[:marca].to_s == marca.id.to_s %>>
                <%= marca.Nombre %>
              </option>
            <% end %>
          </select>
        </div>
      </form>
    </div>

    <div class="catalog-navbar__actions">
      <%= link_to "/online_catalog?phone=#{params[:phone]}", class: "catalog-navbar__action-btn" do %>
        Catálogo con Precios
      <% end %>
    </div>

  </div>
</div>