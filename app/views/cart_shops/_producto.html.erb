<div class="col-xl-3 col-lg-3 col-md-4 col-sm-6 col-12 mb-4">
  <article class="product-card h-100">

    <!-- Imagen -->
    <div class="product-card__image">
      <a href="<%= "product_details/#{producto.id}?phone=#{params[:phone]}" %>" class="product-card__link">
        <img src="<%= url %>" class="product-card__img" alt="<%= producto.Nombre %>" />
      </a>
    </div>

    <!-- Info -->
    <div class="product-card__body">
      <div class="product-card__meta">
        <span class="product-card__brand"><%= producto.MarcaNombre %></span>
        <span class="product-card__dot">•</span>
        <span class="product-card__measure"><%= producto.MedidaNombre %></span>
      </div>

      <h3 class="product-card__title" title="<%= producto.Nombre %>">
        <%= producto.Nombre %>
      </h3>

      <div class="product-card__footer">
        <div class="product-card__price">
        <p style="margin:0; font-size: 12px; opacity:.85;">
          Stock: <strong><%= producto.StockTotal.to_i %></strong>
        </p>
        </div>

        <div class="product-card__cta">
          <%= button_to "product_details/#{producto.id}?phone=#{params[:phone]}",
                class: "btn btn-primary w-100 product-card__btn",
                method: :get do %>
            Ver más
            <input type="hidden" name="phone" value="<%= params[:phone] %>">
          <% end %>
        </div>
      </div>
    </div>

  </article>
</div>