  <body>
    <header>
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-2">
                    <div class="navbar-header">
                      <a class="navbar-brand" href="#">
                        <%= image_tag("logo.png", :alt => Empresa.find(1).nombre , class:'logo') %>
                      </a>
                    </div>
                </div>
                <div class="col-md-2 col-sm-12 col-xs-12 pull-right">
                    <div class="cartResponsive">
                        <button class="btn btn-naranja btn-lg" onClick="shopCartModal();"><span class="glyphicon glyphicon-shopping-cart"></span></button>
                        <input type="button" class="btn btn-naranja btn-lg" disabled id="numOfProd" value="0"/>

                    </div>
                </div>
                <div class="col-md-8">
                      <div class="col-md-2 col-sm-12 col-xs-12 nitField" style="display:none;">
                        <input type="number" class="form-control" id="nit" placeholder="Nit sin guiones">
                        <br class="" />
                      </div>
                      <div class="form-group">
                          <div class="col-md-8">
                              <div class="input-group input-group-lg">
                                  <div class="input-group-btn categorias">
                                    <button type="button" class="btn btn-naranja dropdown-toggle" data-toggle="dropdown"><i id="tag"></i> <span class="fa fa-caret-down"></span></button>
                                    <ul class="dropdown-menu" id="newCats">
                                      <%  @categoriasCatalogo.each do |item| %>
                                        <li><a href="#" onClick="getProdsByCategory(<%= item.id %>, '<%= item.Nombre %>')" title=""><%= item.Nombre %></a></li>
                                      <% end %>
                                    </ul>
                                  </div><!-- /btn-group -->
                                  <input type="text" class="form-control" id="searchIn" placeholder="¿Qué estas buscando? ">
                                  <div class="buscar input-group-addon" onclick="" id="search">
                                      <span class=" glyphicon glyphicon-search ">
                                      </span>
                                  </div>
                              </div>
                              <a href="#" class="pull-right" id="showField">¿Tiene nit de mayorista?</a>
                          </div>
                      </div>
                </div>
            </div>
        </div>
    </header>
     <div class="content">
       <% @productos.each do |producto|
         @productoImagenes = ProductImage.where(Producto_id: producto.id)
         imagenes = []
         if @productoImagenes
            @productoImagenes.each do |img|
              imagenes.push(img.descripcion.to_s)
            end
         end
         if @productoImagenes != nil && !@productoImagenes.empty?
           url = asset_url('uploads/'+@productoImagenes[0].descripcion)
         else
           url = image_url("logo.png", :alt => "Logo", :style => "display:inline; height:120px;")
         end
         %>
         <div class="col-sm-2">
         	<article class="col-item">
         		<div class="photo">
               <% if @descuento != nil
                  precioFinal = (producto.Valor_Venta - ((@descuento[0].Porcentaje_Comision/100) * producto.Valor_Venta ))
               else
                  precioFinal = producto.Valor_Venta
               end %>
               <a href="#"> <img src="<%= url %>" class="img-fluid" alt="Product Image" onclick="showMore(<%= imagenes %>, <%= producto.id %>, '<%= producto.Nombre.to_s %>', <%= precioFinal  %>);" /> </a>
         		</div>
         		<div class="info">
         			<div class="row">
         				<div class="price-details col-md-6">
         					<p class="details">
                     <%= producto.MarcaNombre %>
                     <%= producto.MedidaNombre %>
         					</p>
         					<h1 class="productName"><%= producto.Nombre %></h1>
                   <% if @descuento != nil  %>
                        <br>
                        <del class="price-new">Q <%= producto.Valor_Venta  %></del>
         					     <span class="price-new">Q <%= (producto.Valor_Venta - ((@descuento[0].Porcentaje_Comision/100) * producto.Valor_Venta ))  %></span>
                   <% else %>
                        <span class="price-new">Q <%= producto.Valor_Venta  %></span>
                   <% end %>
         				</div>
         			</div>
         			<div class="clearfix"></div>
         		</div>
         	</article>
         </div>
       <% end %>
     </div>
     <div class="modal fade bd-example-modal-lg" id="exampleModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-lg">
       <div class="modal-content">
         <div class="modal-header">
           <h5 class="modal-title" id="exampleModalLabel">Visor de Pre Compra</h5>
           <button type="button" class="close" data-dismiss="modal" aria-label="Close">
             <span aria-hidden="true">&times;</span>
           </button>
         </div>
         <div class="modal-body">
            <section class="section-white">
              <div class="">

                <div id="carousel-example-generic" class="carousel slide" data-ride="carousel">
                  <!-- Indicators -->
                  <ol class="carousel-indicators">
                    <li data-target="#carousel-example-generic" data-slide-to="0" class="active"></li>
                    <li data-target="#carousel-example-generic" data-slide-to="1"></li>
                    <li data-target="#carousel-example-generic" data-slide-to="2"></li>
                  </ol>

                  <!-- Wrapper for slides -->
                  <div class="carousel-inner">

                  </div>

                  <!-- Controls -->
                  <a class="left carousel-control" href="#carousel-example-generic" data-slide="prev">
                    <span class="glyphicon glyphicon-chevron-left"></span>
                  </a>
                  <a class="right carousel-control" href="#carousel-example-generic" data-slide="next">
                    <span class="glyphicon glyphicon-chevron-right"></span>
                  </a>
                </div>

              </div>
            </section>
              <section>
                <table class="table">
                    <tr>
                      <input type="text" name="" id="actualProductImg" value="">
                      <input type="text" name="" id="actualProduct" value="">
                      <input type="text" name="" id="actualProductN" value="">
                      <input type="text" name="" id="actualProductPrice" value="">
                      <td><b>Cantidad:</b></td>
                      <td><input type="integer" name="" value="" id="cantidad" class="form-control"></td>
                    </tr>
                    <tr>
                      <td><b>Medida:</b></td>
                      <td><select  name="" id="medida" class="form-control">
                        <option value="1">S</option>
                        <option value="2">M</option>
                        <option value="3">L</option>
                      </select></td>
                    </tr>
                    <tr>
                      <td></td>
                      <td><button type="button" class="btn btn-primary btn-naranja pull-right" id="addToCart" >Agregar al Carrito</button></td>
                    </tr>
                </table>
              </section>
         </div>
         <div class="modal-footer">
           <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
         </div>
       </div>
     </div>
   </div>
   <div class="modal fade bd-example-modal-lg" id="shopCartModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg " style="width: 95%;">
     <div class="modal-content">
       <div class="modal-header">
         <h5 class="modal-title" id="exampleModalLabel">Carrito</h5>
         <button type="button" class="close" data-dismiss="modal" aria-label="Close">
           <span aria-hidden="true">&times;</span>
         </button>
       </div>
       <div class="modal-body">
            <section  id="cartDetail">
            </section>
            <section  id="clientData" style="display:none;">
                <form action="saveCartOrder" method="POST">
                  <label for="">Nit:</label>
                  <input type="number" required name="nit" value="" class="form-control" placeholder="Nit sin guiones." maxlength="9"/>
                  <label for="">Nombre:</label>
                  <input type="text" required name="cliente" value="" class="form-control" maxlength="35"/>
                  <label for="">Direccion de Entrega:</label>
                  <input type="text" required name="direccionEntrega" value="" class="form-control" maxlength="75"/>
                  <label for="">Direccion de Facturacion:</label>
                  <input type="text" required name="direccionFacturacion" value="" class="form-control" maxlength="75"/>
                  <label for="">Correo:</label>
                  <input type="email" required name="email" value="" class="form-control" maxlength="35"/>
                  <label for="">Telefono de Contacto:</label>
                  <input type="number" required name="telefono" value="" class="form-control" maxlength="8"/>
                  <input type="hidden" name="detailsProds"  id="detailsProds" value="" class="form-control" maxlength="8"/>
                  <br/>
                  <div class="panel panel-info">
                    <div class="panel-heading">Metodo de Pago</div>
                    <div class="panel-body">
                      <table class="table">
                        <tr>
                          <td>Cuentas Bancarias:</td>
                          <td>Link de Pago:</td>
                          <% if  @empresa.pagoContraEntrega %>
                            <td>Pago contra entrega:</td>
                          <% end %>
                        </tr>
                        <tr >
                          <td id="bankAccounts">
                          </td>
                          <td></td>
                          <% if  @empresa.pagoContraEntrega %>
                            <td></td>
                          <% end %>
                        </tr>
                      </table>
                    </div>
                  </div>
                  <input type="submit" name="" value="Enviar Pedido"  class="btn btn-naranja pull-right"/>
                  <button class="g-recaptcha btn btn-naranja "
                  data-sitekey="6LfK7KUZAAAAAACWSnAMEx1P2J6BLA7uFtLjD5W5"
                  data-callback='onSubmit'
                  data-action='submit'
                  type="submit" style="display:none;"
                  >Enviar Pedido</button>
                </form>
            </section>
       </div>
       <div class="modal-footer">
         <button type="button" class="btn btn-naranja confirmDetailBtn"  id="confirmarCompra">Confirmar Compra</button>
         <button type="button" class="btn btn-secondary pull-left" data-dismiss="modal">Regresar</button>
       </div>
     </div>
   </div>
 </div>
