    function showMore(imagenes,actualProduct,actualProductN,actualProductPrice){
      if (!getCookie("acceptCookies")) {
          var cookieAlert = document.querySelector(".cookiealert");
          cookieAlert.classList.add("show");
          alert('Este sitio funciona no funcion sin cookies.')
      }else{
        html = '';
        for(i=0;i <imagenes.length; i++){
          if(i == 0 ){
            $("#actualProductImg").val("/uploads/"+imagenes[i]);
            html += '<div class="item active">'
          }else{
            html += '<div class="item">'
          }
          html +=  '<img src="/uploads/'+imagenes[i]+'" class="img-fluid" alt="Product Image" />'
          html += '</div>'
        }
        $("#actualProduct").val(actualProduct)
        $("#actualProductN").val(actualProductN)
        $("#actualProductPrice").val(actualProductPrice)

        $(".carousel-inner").html(html);
        $("#exampleModal").modal('show');
      }
    }
