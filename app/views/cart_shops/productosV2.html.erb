      if (getCookie("COOKIE_ITEMS_LIST")!= null){
        rows = JSON.parse(getCookie("COOKIE_ITEMS_LIST"));
        rows.push( JSON.stringify(row) );
        setCookie("COOKIE_ITEMS_NUMBER", rows.length ,"1")
      }else{
        rows = [JSON.stringify(row)]
      }
      setCookie("COOKIE_ITEMS_LIST", JSON.stringify(rows),"1")
      $("#numOfProd").val(getCookie("COOKIE_ITEMS_NUMBER"));
      $("#cantidad").val('')
      $("#medida").val('')
      $("#exampleModal").modal('hide');
    });
    function removeCarProductCookie(index){
        rows = JSON.parse(getCookie("COOKIE_ITEMS_LIST"));
         rows.splice(index,1);
        setCookie("COOKIE_ITEMS_LIST", JSON.stringify(rows)  ,"1")
        setCookie("COOKIE_ITEMS_NUMBER", rows.length   ,"1")
        $("#numOfProd").val(getCookie("COOKIE_ITEMS_NUMBER"));
        showProducts()
    }
