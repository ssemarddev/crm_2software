<% @empresa = Empresa.find(1) %>
<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta charset="utf-8">
    <title><%= Empresa.find(1).nombre %></title>
    <%= stylesheet_link_tag    'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= stylesheet_link_tag    'out_of_session_views', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= stylesheet_link_tag    'productos', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag 'jquery', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag 'bootstrap', 'data-turbolinks-track': 'reload' %>
    <script src="https://www.google.com/recaptcha/api.js"></script>
    <style>

        header{
          /*background-color: #444242;*/
          background-color: <%= Empresa.find(1).color1 %>;
          color: white;
          padding: 3px;
          padding-top: 2%;
        }

        .btn-naranja{
          color: #fff;
          /*background-color: #F0AD4E;*/
          background-color: <%= Empresa.find(1).color2 %>;
        }
        .color-naranja{
         background-color: #F0AD4E;
         border:medium;
         }
         .logo {
           float: left;
           margin-top: -30px;
         }
         .deleteButton{
           border-bottom-left-radius: 0px;
           float: right;
           position: fixed;
