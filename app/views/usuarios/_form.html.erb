<%= form_for(usuario) do |f| %>
  <% if usuario.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(usuario.errors.count, "error") %> prohibited this usuario from being saved:</h2>

      <ul>
      <% usuario.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>
<div class="row">
  <div class="col-md-6 col-lg-6 col-sm-6 col-xs-6">
    <div class="field">
      <%= f.label :User_Name %>
      <%= f.text_field :User_Name, class: 'form-control'%>
    </div>

    <div class="field">
      <%= f.label :password %>
      <%= f.password_field :password , class: 'form-control'%>
    </div>

    <div class="field">
      <%= f.label :password_confirmation %>
      <%= f.password_field :password_confirmation , class: 'form-control'%>
    </div>

    <div class="field">
      <%= f.label :Nombres %>
      <%= f.text_field :Nombres , class: 'form-control'%>
    </div>

    <div class="field">
      <%= f.label :Apellidos %>
      <%= f.text_field :Apellidos , class: 'form-control'%>
    </div>

    <div class="field">
      <%= f.label :Correo %>
      <%= f.text_field :Correo , class: 'form-control'%>
    </div>

    <div class="field">
      <%= f.label :Fecha_Nacimiento %>
      <%= date_field(:usuario,:Fecha_Nacimiento, class: 'form-control') %>
    </div>

    <div class="field">
      <%= f.label :Telefono %>
      <%= f.number_field :Telefono , class: 'form-control'%>
    </div>

    <div class="field">
      <%= f.label :Telefono1 %>
      <%= f.number_field :Telefono1 , class: 'form-control'%>
    </div>

    <div class="field">
      <%= f.label :Porcentaje_Descuento %>
      <%= f.text_field :Porcentaje_Descuento , class: 'form-control'%>
    </div>

    <div class="field">

      <%= f.hidden_field :Nivel_Acceso , class: 'form-control', value: 3%>
    </div>

    <div class="field">
      <%= f.label :Estado %>
      <%= f.check_box :Estado, checked: true %>
    </div>

    <!--  <div class="field">
      < f.label :creado_por %>
      < f.number_field :creado_por %>
    </div>

    <div class="field">
      < f.label :actualizado_por %>
      < f.number_field :actualizado_por %>
    </div>

    <div class="field">
      < f.label :creado %>
      < f.date_select :creado %>
    </div>

    <div class="field">
      < f.label :actualizado %>
      < f.datetime_select :actualizado %>
    </div>-->
  </div>
  <div class="col-md-6 col-lg-6 col-sm-6 col-xs-6">
    <div class="panel panel-info">
      <div class="panel-heading">Acciones:</div>
      <div class="panel-body">
        <button type="submit" name="button" class="btn btn-primary"><i class="fontawesome-save"></i> Guardar</button>
        <%= link_to 'Regresar', usuarios_path, class: 'btn btn-default' %>
      </div>
    </div>
  </div>
</div>

<% end %>
