<%= form_for(producto) do |f| %>
  <% if producto.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(producto.errors.count, "error") %> prohibited this producto from being saved:</h2>

      <ul>
      <% producto.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

<p id="notice"><%= notice %></p>

<div class="row">
  <div class="col-xs-12 col-sm-12 col-md-6">
    <% if @edit %>
      <div class="field">
        <%= f.label :Codigo %>  
          <%= f.text_field :Codigo , class: "form-control" %>
        
      </div>
    <% end %>
    <div class="field">
      <%= f.label :Nombre %>
      <%= f.text_field :Nombre, class: "form-control" %>
    </div>

    <div class="field">
      <%= f.label :Marca_id %>
      <%= collection_select(:producto, :Marca_id, Marca.where(:Estado => true), :id, :Nombre, {:prompt => true}, class: "form-control" )%>
    </div>

    <div class="field">
      <%= f.label "Proveedor" %>
      <%= collection_select(:producto, :ClienteProveedor_id, ClienteProveedor.where(:Estado => true, :Tipo=>2), :id, :Nombre, {:prompt => true}, class: "form-control") %>
    </div>

    <div class="field">
      <%= f.label "Tipo Producto" %>
      <%= collection_select(:producto, :TipoProducto_id, TipoProducto.where(:Estado => true), :id, :Nombre, {:prompt => true}, class: "form-control") %>
    </div>

    <!-----  pruebas bryan   ------------------------------------->

    <div class="field">
      <%= f.label :Mayorista %>
      <%= f.text_field :preciouno, class: "form-control" %>
    </div>


    <div class="field">
      <%= f.label :Mayorista_Instalado %>
      <%= f.text_field :preciodos, class: "form-control" %>
    </div>



    <div class="field">
      <%= f.label :Cliente_Final_Descuento %>
      <%= f.text_field :preciotres, class: "form-control" %>
    </div>


    <div class="field">
      <%= f.label :Cliente_Final %>
      <%= f.text_field :preciocuatro, class: "form-control" %>
    </div>

    <!-----  salida pruebas bryan  ------------------------------------->
    

    <div class="field">
      <%= f.label :Minimos %>
      <%= f.number_field :Minimos, class: "form-control" %>
    </div>

    <div class="field">
      <%= f.label :Valor_Compra %>
      <%= f.text_field :Valor_Compra, class: "form-control" %>
    </div>

    <div class="field">
      <%= f.label :Valor_Venta %>
      <%= f.text_field :Valor_Venta, class: "form-control" %>
    </div>

    <div class="field">
      <%= f.label :Medida_id %>
      <%= collection_select(:producto, :Medida_id, Medida.where(:Estado => true), :id, :Nombre, {:prompt => true}, class: "form-control") %>
    </div>

    <div class="field">
      <%= f.label :Fila %>
      <%= f.text_field :Fila, class: "form-control" %>
    </div>

    <div class="field">
      <%= f.label :Columna %>
      <%= f.text_field :Columna, class: "form-control" %>
    </div>
  </div>
  <div class="col-xs-12 col-sm-12 col-md-6">
    <div class="col-xs-12 col-sm-12 col-md-12">
      <%= f.file_field :producto, :multiple => 'multiple', :name => 'dropImage[]', :accept=>"image/jpeg", :id=>"dropImage"%>
      <!--input type="file" class="custom-file-input" id="dropImage" aria-describedby="inputGroupFileAddon01" name="producto[dropImage[]]" accept="image/png, image/jpeg" multiple="true">-->
      <img src="" class="drop-image" />
      <div id="drop-container">
          <div class="drop-area-text">Previsualizacion</div>
          <% @producto.product_image.each do |pI| %>
            <div class="containerImg preview-<%= pI.id %> ">
              <img src="<%= asset_url('uploads/'+pI.descripcion)%>" class="preview" />
              <div class="overlay">
                <div class="text deleteImg" data-imgId="<%= pI.id %>" >Eliminar</div>
              </div>
            </div>
          <% end %>
      </div>
      <div id="deletedImg">

      </div>
      <div class="panel panel-info">
        <div class="panel-heading"> <h3 class="panel-title">Acciones</h3> </div>
        <div class="panel-body">
          <%= f.submit "Guardar", class:'btn btn-primary' %>
          <%= link_to 'Regresar', productos_path, class:'btn btn-default' %>
        </div>
      </div>
      <div class="col-xs-12 col-sm-12 col-md-6">
        <table class="qr" style="border-width: 0; border-style: none; border-color: #0000ff; border-collapse: collapse; width: 150px; display:inline; float:left">
          <% if @qr %>
            <% @qr.modules.each_index do |x| %>
                <tr>
                  <% @qr.modules.each_index do |y| %>
                      <% if @qr.qrcode.checked?(x,y) %>
                          <td class="black" style="background-color: #000;  border-width: 0; border-style: none; border-color: #0000ff; border-collapse: collapse; padding: 0; margin: 0; width: 10px; height: 5px;"/>
                      <% else %>
                          <td class="black" style="background-color: #fff;  border-width: 0; border-style: none; border-color: #0000ff; border-collapse: collapse; padding: 0; margin: 0; width: 10px; height: 5px;"/>
                      <% end %>
                  <% end %>
                </tr>
            <% end %>
          <% end %>
        </table>
      </div>
    </div>
    <% if session[:version].include? "3.0" %>
      <div class="col-xs-12 col-sm-12 col-md-12">
        <table class="table">
          <thead>
            <tr>
              <th>Caracteristica</th>
              <th>Valor</th>
              <th></th>
            </tr>
            <tr>
              <td><input type="text" name="caracteristicas[]" value="" class="form-control"></td>
              <td><input type="text" name="valores[]" value="" class="form-control"></td>
              <td><button type="button" name="button" class="btn btn-primary">+</button></td>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Color</td>
              <td>Rojo</td>
              <td><button type="button" name="button" class="btn btn-danger">X</button></td>
            </tr>
            <tr>
              <td>Modelo</td>
              <td>HTC912</td>
              <td><button type="button" name="button" class="btn btn-danger">X</button></td>
            </tr>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
<script type="text/javascript">
  $(document).on("keydown", ":input:not(textarea)", function(event) {
      return event.key != "Enter";
  });
</script>
<% end %>
