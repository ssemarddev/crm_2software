<p id="notice"><%= notice %></p>

<h1>Bancos</h1>

<table class="table">
  <thead>
    <tr>
      <th>Nombre</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @bancos.each do |banco| %>
      <tr>
        <td><%= banco.nombre %></td>
        <td><%= link_to 'Ver', banco, class: 'btn btn-info' %></td>
        <td><%= link_to 'Editar', edit_banco_path(banco), class: 'btn btn-warning' %></td>
        <td><%= link_to 'Eliminar', banco, method: :delete, data: { confirm: 'Are you sure?' }, class: 'btn btn-danger'%></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'Nuevo Banco', new_banco_path, class: 'btn btn-primary' %>
