<%= form_for(opcion_role) do |f| %>
  <% if opcion_role.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(opcion_role.errors.count, "error") %> prohibited this opcion_role from being saved:</h2>

      <ul>
      <% opcion_role.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

<div class="row">
  <div class="col-md-6 col-lg-6 col-sm-6 col-xs-6">
    <div class="field">
      <%= f.label :opcion_id %>
      <%= collection_select(:opcion_role, :opcion_id, Opcion.where(:Estado => true), :id, :Nombre, {:prompt => true}, class: 'form-control') %>
      <!-- f.text_field :opcion_id  -->
    </div>

    <div class="field">
      <%= f.label :role_id %>
      <%= collection_select(:opcion_role, :role_id, Role.where(:Estado => true), :id, :Nombre, {:prompt => true}, class: 'form-control') %>
      <!--begin f.text_field :role_id -->
    </div>

    <div class="field">
      <%= f.label :Estado %>
      <%= f.check_box :Estado, checked: true %>
    </div>
<!--
  <div class="field">
     f.label :creado_por %>
     f.number_field :creado_por %>
  </div>

  <div class="field">
     f.label :actualizado_por %>
     f.number_field :actualizado_por %>
  </div>

  <div class="field">
