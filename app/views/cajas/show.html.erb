<p id="notice"><%= notice %></p>

<button type="button" onclick="printDiv();" name="button" class="btn btn-info pull-right">Imprimir</button>
<div id="DivIdToPrint">
  <h1>Caja <%= @caja.Nombre %></h1>
  <div class="" style="display:inline;">
  <%
    @empresa = Empresa.find(1)
  %>
  <%= image_tag("logo.png", :alt => "Logo", :style => "display:block; height:180px;width:150px;") %>

  <table class="table " style="display:inline" >
    <thead>
      <tr>
        <td><strong>Usuario:</strong></td>
        <td><%= @caja.usuario.Nombres %></td>
      </tr>
      <tr>
        <td><strong>Fecha y Hora de Apertura: </strong></td>
        <td><%= @caja.created_at %></td>
      </tr>
      <tr>
        <td><strong>Fecha y Hora de Cierre: </strong></td>
        <td><%= @caja.updated_at %></td>
      </tr>
      <tr>
        <td><strong>Efectivo Inicial:</strong></td>
        <td><%= @caja.InicialEfectivo %></td>
      </tr>
      <tr>
        <td><strong>Total Final:</strong></td>
        <td><%= @caja.FinalEfectivo %></td>
      </tr>
      <tr>
        <td><strong>Total POS:</strong></td>
        <td><%= @caja.FinalPos %></td>
      </tr>
      <tr>
        <td><strong>Total:</strong></td>
        <td><%= @caja.FinalEfectivo.to_f +  @caja.FinalPos.to_f %></td>
      </tr>
      <tr>
        <td><strong>Abierta Por:</strong></td>
        <td><%= @caja.creado_por ? Usuario.find(@caja.creado_por).Nombres : "" %></td>
      </tr>
      <tr>
        <td><strong>Cerrada Por:</strong></td>
        <td><%= @caja.actualizado_por ? Usuario.find(@caja.actualizado_por).Nombres : "" %></td>
      </tr>
    </thead>
  </table>
  </div>
</div>
<script type="text/javascript">
function printDiv()
{
  var divToPrint=document.getElementById('DivIdToPrint');
  var newWin=window.open('','Print-Window');
  newWin.document.open();
  newWin.document.write('<html><body onload="window.print()">'+divToPrint.innerHTML+'</body></html>');
  newWin.document.close();
  setTimeout(function(){newWin.close();},10);
}
</script>
