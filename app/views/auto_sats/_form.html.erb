  <div class="field">
    <%= f.label :creado_por %>
    <%= f.number_field :creado_por %>
  </div>

  <div class="field">
    <%= f.label :actualizado_por %>
    <%= f.number_field :actualizado_por %>
  </div>

  <div class="field">
    <%= f.label :creado %>
    <%= f.date_select :creado %>
  </div>

  <div class="field">
    <%= f.label :actualizado %>
    <%= f.datetime_select :actualizado %>
