<%= form_for(auto_sat) do |f| %>
  <% if auto_sat.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(auto_sat.errors.count, "error") %> prohibited this auto_sat from being saved:</h2>

      <ul>
      <% auto_sat.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :Numero_autorizacion %>
    <%= f.number_field :Numero_autorizacion %>
  </div>

  <div class="field">
    <%= f.label :Serie %>
    <%= f.text_field :Serie %>
  </div>

  <div class="field">
    <%= f.label :Actual %>
    <%= f.number_field :Actual %>
  </div>

  <div class="field">
    <%= f.label :Inicio %>
    <%= f.number_field :Inicio %>
  </div>

  <div class="field">
    <%= f.label :Fin %>
    <%= f.number_field :Fin %>
  </div>

  <div class="field">
    <%= f.label :Bodega_id %>
    <%= collection_select(:auto_sat, :Bodega_id, Bodega.where(:Estado => true), :id, :Nombre, {:prompt => true}) %>
  </div>

  <div class="field">
    <%= f.label :Estado %>
    <%= f.check_box :Estado %>
  </div>
