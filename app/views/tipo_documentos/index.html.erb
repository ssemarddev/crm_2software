<p id="notice"><%= notice %></p>

<h1>Tipo Documentos</h1>


<table id="productos" class="table table-condensed dataTable">
  <thead>
    <tr>
      <th>Nombre</th>
      <th>Estado</th>
      <th>Creado por</th>
      <th>Actualizado por</th>
      <th>Creado</th>
      <th>Actualizado</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @tipo_documentos.each do |tipo_documento| %>
      <tr>
        <td><%= tipo_documento.Nombre %></td>
        <td><%= tipo_documento.Estado %></td>
        <td><%= tipo_documento.creado_por %></td>
        <td><%= tipo_documento.actualizado_por %></td>
        <td><%= tipo_documento.creado %></td>
        <td><%= tipo_documento.actualizado %></td>
        <td><%= link_to 'Show', tipo_documento %></td>
        <td><%= link_to 'Edit', edit_tipo_documento_path(tipo_documento) %></td>
        <td><%= link_to 'Destroy', tipo_documento, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Tipo Documento', new_tipo_documento_path %>
