<%= form_for(cliente_proveedor) do |f| %>
  <% if cliente_proveedor.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(cliente_proveedor.errors.count, "error") %> prohibited this cliente_proveedor from being saved:</h2>

      <ul>
      <% cliente_proveedor.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>
<div class="row">
  <div class="col-md-6 col-lg-6 col-sm-6 col-xs-6">

    <div class="field">
      <%= f.hidden_field :Tipo, class: 'form-control', value: params[:format].to_i %>
      <%= f.hidden_field :Destino, class: 'form-control', value: @noRedirect %>
    </div>

    <div class="field">
      <%= f.label :nit %>
      <%= f.text_field :nit, class: 'form-control', required: true %>
    </div>

    <div class="field">
      <%= f.label :Nombre %>
      <%= f.text_field :Nombre, class: 'form-control' , required: true%>
    </div>

    <div class="field">
      <%= f.label :direccion %>
      <%= f.text_field :direccion, class: 'form-control' %>
    </div>

    <div class="field">
      <%= f.label :Porcentaje_Descuento %>
      <%= f.number_field :Porcentaje_Comision, class: 'form-control' %>
    </div>


    <div class="field">
      <%= f.label :Telefono %>
      <%= f.number_field :Fax, class: 'form-control' %>
    </div>
    <% if session[:version].include? "2.0" %>
      <div class="field">
        <%= f.label :Ruta %>
        <select class="form-control" name="cliente_proveedor[ruta_id]">
          <% Rutum.where(status:true,tipo:1).each do |r| %>
          <option value="<%= r.id %>"><%= r.nombre %> - <% r.piloto %></option>
          <% end%>
        </select>
      </div>
      <div class="field">
        <%= f.label :Tipo %>
        <select class="form-control" name="clasificacion">
          <option value="A">A - Bueno</option>
          <option value="B">B - Malo</option>
          <option value="C">C - Regular</option>
        </select>
      </div>

      <div class="field">
        <%= f.label :Observacion %>
        <%= f.text_field :observacion, class: 'form-control' %>
      </div>
    <% end %>

    <div class="field">
      <%= f.label :Estado %>
      <%= f.check_box :Estado, checked: true %>
    </div>
  <!--
    <div class="field">
      < f.label :creado_por %>
      < f.number_field :creado_por %>
    </div>

    <div class="field">
      < f.label :actualizado_por %>
      < f.number_field :actualizado_por %>
    </div>

    <div class="field">
      < f.label :creado %>
      < f.date_select :creado %>
    </div>

    <div class="field">
      < f.label :actualizado %>
      < f.datetime_select :actualizado %>
    </div>-->
  </div>
  <div class="col-md-6 col-lg-6 col-sm-6 col-xs-6">
    <div class="panel panel-info">
      <div class="panel-heading">Acciones:</div>
      <div class="panel-body">
        <button type="submit" name="button" class="btn btn-primary"><i class="fontawesome-save"></i> Guardar</button>
        <% if !@noRedirect
            if cliente_proveedor != nil%>
              <%= link_to 'Regresar', '/cliente_proveedor_tipo/'+ cliente_proveedor.Tipo.to_s , class: 'btn btn-default' %>
            <% else %>
              <%= link_to 'Regresar', '/cliente_proveedor_tipo/'+ params[:format].to_s , class: 'btn btn-default' %>
            <% end
        end %>
      </div>
    </div>
  </div>
</div>
<% end %>
