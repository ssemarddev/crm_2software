<%
avanceTodas = Tarea.where('"tareas".proyecto_id= '+(@proyecto.id).to_s).count
avanceAbiertas = Tarea.where('"tareas".fecha_finalizado is null and  "tareas".proyecto_id= '+(@proyecto.id).to_s).count
avanceCerradas = Tarea.where('"tareas".fecha_finalizado is not null and  "tareas".proyecto_id= '+(@proyecto.id).to_s).count
%>
<div class="row">
  <div class="col-md-6">
    <table class="table table-dark table-striped">
      <thead>
        <tr>
          <th colspan="6" class="align-center"><h1>Proyecto <%=  @proyecto.nombre %></h1><h4>Avance Total: <%= ((avanceCerradas.to_f/avanceTodas.to_f)*100).round(2) %>%</h4></th>
        </tr>
        <tr>
          <th></th>
          <th>Abiertas: <%= avanceAbiertas%></th>
          <th>Cerradas: <%= avanceCerradas%></th>
          <th>Total: <%= avanceTodas%></th>
          <th></th>
          <th></th>
        </tr>
        <tr>
          <th>Tareas</th>
          <th colspan="3">Avance</th>
          <th>Responsable</th>
          <th>Fecha Fin</th>
        </tr>
      </thead>
      <tbody>
        <%
          tareas = Tarea.where(proyecto:@proyecto.id).order(subproyecto_id: :desc)
          tareas.each do |t|
        %>
        <%
          texto = ""
          if t.subproyecto
            texto = "&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"
        %>
            <tr><td colspan="4"><strong><%= (t.subproyecto.nombre).upcase %></strong></td></tr>
        <%
          end
        %>
            <tr>
              <td><%= link_to texto.html_safe + t.nombre, t %></td>
              <td colspan="3">
                <div class="progress">
                  <% if t.fecha_finalizado
                      if t.fecha_finalizado >= t.fechafin
                        status = "Finalizado"
                        clase  = "progress-bar-success"
                        statusBar = 100
                      elsif t.fecha_finalizado < t.fechafin
                        status = "Finalizado antes de tiempo"
                        clase  = "progress-bar-success"
                        statusBar = 100
                      else
                        if Date.parse(Time.now.strftime("%Y-%m-%d")) < Time.now
                          status = "Ok"
                          clase  = "progress-bar-info"
                          statusBar = 3
                        end
                      end
                    else
                      if  Date.parse(Time.now.strftime("%Y-%m-%d")) > t.fechafin
                        status = "Atrasado"
                        clase  = "progress-bar-danger"
                        statusBar = 3
                      else
                        status = "OK"
                        clase  = "progress-bar-info"
                        statusBar = 3
                      end
                    end
                  %>

                  <div class="progress-bar <%= clase %>" role="progressbar" aria-valuenow="60" aria-valuemin="0" aria-valuemax="100" style="width: <%=statusBar%>%;">
                      <span class="sr-only">60% Complete</span>
                  </div>
                  <span class="progress-type"><%= status %></span>
                  <span class="progress-completed"><%= statusBar-3 %>%</span>

                </div>
              </td>
              <td><%= t.usuario.User_Name%></td>
              <td><%= t.fechafin %></td>
            </tr>
        <%
          end
        %>
      </tbody>
    </table>
  </div>
  <div class="col-md-6">
    <h1>Desempeño del Personal</h1>
    <%
      usuarios = Usuario.all
      usuarios.each do |u|
      avanceTodas = Tarea.where('"tareas".usuario_id = '+u.id.to_s+' and "tareas".proyecto_id= '+(@proyecto.id).to_s).count
      avanceAbiertas = Tarea.where('"tareas".usuario_id = '+u.id.to_s+' and "tareas".fecha_finalizado is null and  "tareas".proyecto_id= '+(@proyecto.id).to_s).count
      avanceCerradas = Tarea.where('"tareas".usuario_id = '+u.id.to_s+' and "tareas".fecha_finalizado is not null and  "tareas".proyecto_id= '+(@proyecto.id).to_s).count
      rendimiento = (avanceCerradas*100)/avanceTodas.to_f
    %>

      <div class="progress">
        <div class="progress-bar progress-bar-info " role="progressbar" aria-valuenow="60" aria-valuemin="0" aria-valuemax="100" style="width:<%=rendimiento.to_s%>%;">
            <span class="sr-only"><%= rendimiento.to_s %>%</span>
        </div>
        <span class="progress-type"><%= u.User_Name %></span>
        <span class="progress-completed"><%= rendimiento.to_s %>%</span>
      </div>
    <%
      end
    %>
  </div>
</div>
